    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.16.3",
    "resend": "^6.11.0",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "drizzle-kit": "^0.31.8",
    "prettier": "^3.7.4"
