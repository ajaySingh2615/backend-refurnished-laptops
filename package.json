{
  "name": "refurbished-laptops-api",
  "version": "0.1.0",
  "private": true,
  "description": "Express API — refurbished laptops e-commerce backend",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "node --watch server.js",
    "start": "node server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
