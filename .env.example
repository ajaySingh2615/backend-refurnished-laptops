NODE_ENV=development
PORT=5000

# PostgreSQL (matches docker-compose defaults — change for production)
# Use 127.0.0.1 + sslmode=disable on Windows if localhost hangs or migrate stalls
DATABASE_URL=postgresql://app:app@127.0.0.1:5433/refurbished_laptops?sslmode=disable

# Comma-separated origins for browser clients (Next.js dev default)
CORS_ORIGIN=http://localhost:3000

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=30d

# Google OAuth
GOOGLE_CLIENT_ID=807513090179-mnk0ra11nl0sc07lqv35c4e7r2mg33lc.apps.googleusercontent.com

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev
